        "type": "select",
        "options": ["Desk job", "Physical work", "Mixed"]
      },
      {
        "key": "goals",
        "question": "What do you want to improve?",
        "type": "text"
      }
    ],
    "soap": {
      "S": [
        "Pain description",
        "Onset and duration",
        "Functional limitations"
      ],
      "O": ["Postural indicators (inferred)", "Mobility issues"],
      "A": [
        "Musculoskeletal dysfunction pattern",
        "Severity classification",
        "Chronic vs acute"
      ],
      "P": []
    }
  },
