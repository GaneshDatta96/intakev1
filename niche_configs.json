{
  "functional_medicine": {
    "label": "Functional Medicine",
    "questionnaire": [
      {
        "key": "chief_complaint",
        "question": "What are your main health concerns?",
        "type": "text"
      },
      {
        "key": "duration",
        "question": "How long have you been experiencing this?",
        "type": "select",
        "options": ["<1 month", "1-6 months", "6-12 months", "1+ years"]
      },
      {
        "key": "symptoms",
        "question": "Select your symptoms",
        "type": "multi",
        "options": [
          "Fatigue",
          "Digestive issues",
          "Brain fog",
          "Hormonal imbalance",
          "Sleep issues"
        ]
      },
      {
        "key": "medical_history",
        "question": "Any diagnosed conditions?",
        "type": "text"
      },
      {
        "key": "medications",
        "question": "Current medications or supplements?",
        "type": "text"
      },
      {
        "key": "diet",
        "question": "Describe your diet",
        "type": "text"
      },
      {
        "key": "sleep",
        "question": "Sleep quality",
        "type": "scale",
        "min": 1,
        "max": 10
      },
      {
        "key": "stress",
        "question": "Stress level",
        "type": "scale",
        "min": 1,
        "max": 10
      },
      {
        "key": "goals",
        "question": "What are your health goals?",
        "type": "text"
      }
    ],
    "soap": {
      "S": [
        "Chief complaint",
        "Symptom timeline",
        "Lifestyle factors",
        "Medical history"
      ],
      "O": ["Reported vitals (if any)", "Patterns from intake"],
      "A": [
        "Functional imbalance patterns",
        "Lifestyle contributors",
        "Chronicity assessment",
        "Risk flags"
      ],
      "P": []
    }
  },
  "chiropractor": {
    "label": "Chiropractic",
    "questionnaire": [
      {
        "key": "pain_location",
        "question": "Where is your pain located?",
        "type": "multi",
        "options": ["Neck", "Back", "Lower back", "Shoulder", "Head"]
      },
      {
        "key": "pain_severity",
        "question": "Pain level (1-10)",
        "type": "scale",
        "min": 1,
        "max": 10
      },
      {
        "key": "duration",
        "question": "How long have you had this pain?",
        "type": "select",
        "options": ["<1 week", "1-4 weeks", "1-6 months", "6+ months"]
      },
      {
        "key": "trigger",
        "question": "What caused it?",
